%%{init: {'theme': 'dark'}}%%
flowchart LR
    subgraph P1["Phase 1<br/>Visibility"]
        P1A["Credential<br/>Inventory"]
        P1B["Audit Logging<br/>Baseline"]
        P1C["Threat Model<br/>Assessment"]
    end

    subgraph P2["Phase 2<br/>Reduce Exposure"]
        P2A["Shorten TTLs<br/>(static → 24h → 1h)"]
        P2B["Unique Agent<br/>Identifiers"]
        P2C["Basic<br/>Revocation"]
    end

    subgraph P3["Phase 3<br/>Task Scoping"]
        P3A["Define Scope<br/>Taxonomy"]
        P3B["Map Tasks<br/>to Scopes"]
        P3C["Scope Validation<br/>at Resources"]
    end

    subgraph P4["Phase 4<br/>Full Zero-Trust"]
        P4A["SPIFFE/SPIRE<br/>Ephemeral IDs"]
        P4B["mTLS<br/>Everywhere"]
        P4C["Anomaly<br/>Detection"]
    end

    subgraph P5["Phase 5<br/>Delegation"]
        P5A["Delegation<br/>Token Format"]
        P5B["Chain<br/>Verification"]
        P5C["Delegation<br/>Monitoring"]
    end

    subgraph P6["Phase 6<br/>Optimize"]
        P6A["Tune Scopes<br/>& TTLs"]
        P6B["Extend to<br/>All Frameworks"]
        P6C["Track Standards<br/>Evolution"]
    end

    P1 ==>|2-4 weeks| P2
    P2 ==>|4-8 weeks| P3
    P3 ==>|8-16 weeks| P4
    P4 ==>|8-12 weeks| P5
    P5 ==>|4-8 weeks| P6
    P6 -.->|ongoing| P6

    P1A --> P1B --> P1C
    P2A --> P2B --> P2C
    P3A --> P3B --> P3C
    P4A --> P4B --> P4C
    P5A --> P5B --> P5C
    P6A --> P6B --> P6C

    classDef phase1 fill:#7c3aed,stroke:#a78bfa,color:#f8fafc,stroke-width:2px
    classDef phase2 fill:#4f46e5,stroke:#818cf8,color:#f8fafc,stroke-width:2px
    classDef phase3 fill:#0369a1,stroke:#38bdf8,color:#f8fafc,stroke-width:2px
    classDef phase4 fill:#0f766e,stroke:#2dd4bf,color:#f8fafc,stroke-width:2px
    classDef phase5 fill:#b45309,stroke:#fbbf24,color:#f8fafc,stroke-width:2px
    classDef phase6 fill:#be185d,stroke:#f472b6,color:#f8fafc,stroke-width:2px

    class P1A,P1B,P1C phase1
    class P2A,P2B,P2C phase2
    class P3A,P3B,P3C phase3
    class P4A,P4B,P4C phase4
    class P5A,P5B,P5C phase5
    class P6A,P6B,P6C phase6
