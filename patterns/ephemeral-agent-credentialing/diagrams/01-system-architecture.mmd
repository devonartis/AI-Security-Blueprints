%%{init: {'theme': 'dark'}}%%
flowchart TD
    subgraph ORCH["Orchestration Layer"]
        O[Orchestrator]
    end

    subgraph IDENTITY["Identity & Credentials"]
        direction LR
        C1["1 Ephemeral<br/>Identity Issuance"]
        C2["2 Short-Lived<br/>Task-Scoped Tokens"]
    end

    subgraph ENFORCEMENT["Zero-Trust Enforcement"]
        direction LR
        C3["3 mTLS + Token<br/>Validation"]
        C4["4 Automatic Expiration<br/>& Revocation"]
    end

    subgraph MULTIAGENT["Multi-Agent Security"]
        direction LR
        C6["6 Agent-to-Agent<br/>Mutual Auth"]
        C7["7 Delegation Chain<br/>Verification"]
    end

    subgraph OBSERVABILITY["Observability & Audit"]
        direction LR
        C5["5 Immutable<br/>Audit Logging"]
        C8["8 Operational<br/>Observability"]
    end

    subgraph AGENTS["Agent Instances"]
        A1[Agent A]
        A2[Agent B]
        A3[Agent C]
    end

    subgraph RESOURCES["Protected Resources"]
        R1[(Database)]
        R2[API Service]
        R3[File Store]
    end

    O -->|spawns| A1
    O -->|spawns| A2
    O -->|spawns| A3

    A1 -->|attests| C1
    C1 -->|issues SPIFFE ID| C2
    C2 -->|scoped JWT| C3

    A1 <-->|mutual auth| A2
    A2 <-->|mutual auth| A3
    A1 --- C6
    A2 --- C7

    C3 -->|validates| R1
    C3 -->|validates| R2
    C3 -->|validates| R3

    C4 -.->|revoke| C2
    C4 -.->|revoke| C3

    A1 -.->|logs| C5
    A2 -.->|logs| C5
    R1 -.->|logs| C5
    C5 --- C8

    classDef orchStyle fill:#7c3aed,stroke:#a78bfa,color:#f8fafc,stroke-width:2px
    classDef identStyle fill:#4f46e5,stroke:#818cf8,color:#f8fafc,stroke-width:2px
    classDef enforceStyle fill:#0369a1,stroke:#38bdf8,color:#f8fafc,stroke-width:2px
    classDef multiStyle fill:#0f766e,stroke:#2dd4bf,color:#f8fafc,stroke-width:2px
    classDef obsStyle fill:#b45309,stroke:#fbbf24,color:#f8fafc,stroke-width:2px
    classDef agentStyle fill:#be185d,stroke:#f472b6,color:#f8fafc,stroke-width:2px
    classDef resStyle fill:#374151,stroke:#9ca3af,color:#f8fafc,stroke-width:2px

    class O orchStyle
    class C1,C2 identStyle
    class C3,C4 enforceStyle
    class C6,C7 multiStyle
    class C5,C8 obsStyle
    class A1,A2,A3 agentStyle
    class R1,R2,R3 resStyle
