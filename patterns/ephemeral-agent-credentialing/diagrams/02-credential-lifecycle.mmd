%%{init: {'theme': 'dark'}}%%
sequenceDiagram
    autonumber
    participant O as Orchestrator
    participant A as Agent Instance
    participant S as SPIRE / Identity<br/>Service
    participant CS as Credential<br/>Service
    participant R as Resource<br/>Server
    participant AL as Audit Log

    rect rgba(79, 70, 229, 0.15)
        Note over O,A: Phase 1 — Spawn & Bootstrap
        O->>A: Spawn agent with task context
        O->>A: Inject one-time launch token<br/>(secure injection, NOT env vars)
    end

    rect rgba(15, 118, 110, 0.15)
        Note over A,CS: Phase 2 — Attest & Issue
        A->>S: Present attestation evidence<br/>(platform properties, launch token)
        S->>S: Validate workload attestation
        S-->>A: Issue SPIFFE SVID<br/>(spiffe://domain/agent/orch/task/uuid)
        A->>CS: Request scoped token<br/>(SVID + required scope)
        CS->>CS: Validate identity<br/>+ authorize scope
        CS-->>A: Issue JWT (TTL: 5 min)<br/>scope: read:Customers:12345
        CS->>AL: Log token issuance
    end

    rect rgba(3, 105, 161, 0.15)
        Note over A,R: Phase 3 — Operate
        A->>R: Request + JWT + mTLS cert
        R->>R: Validate mTLS, JWT sig,<br/>expiry, scope, revocation
        R-->>A: Response (200 OK)
        R->>AL: Log access event
    end

    rect rgba(180, 83, 9, 0.15)
        Note over A,CS: Phase 4 — Renew (if needed)
        A->>CS: Present valid token +<br/>request renewal
        CS-->>A: New JWT (same scope,<br/>fresh TTL)
        CS->>AL: Log renewal event
    end

    rect rgba(190, 24, 93, 0.15)
        Note over A,AL: Phase 5 — Expire / Revoke
        A->>CS: Signal task complete
        CS->>CS: Revoke token immediately
        CS->>AL: Log revocation
        Note over A: Agent terminates.<br/>Credentials destroyed.
    end
