%%{init: {'theme': 'dark'}}%%
flowchart TD
    subgraph THREATS["Threat Landscape"]
        direction TB
        T1["Credential Theft<br/>& Forgery"]
        T2["Compromised<br/>Agent Instance"]
        T3["Lateral<br/>Movement"]
        T4["Malicious<br/>Insider"]
        T5["Rogue / Misbehaving<br/>Agent"]
        T6["Cross-Agent<br/>Privilege Escalation"]
    end

    subgraph DEFENDED["Pattern Defenses"]
        direction TB
        D1["Short-Lived Tokens<br/>+ Crypto Signatures"]
        D2["Unique Identity<br/>+ Scope Limits"]
        D3["mTLS + Zero-Trust<br/>Validation"]
        D4["Immutable Audit<br/>+ Separation of Duty"]
        D5["Auto-Expiry<br/>+ Anomaly Revocation"]
        D6["Delegation Chain<br/>Verification"]
    end

    subgraph NONGOALS["Requires Complementary Controls"]
        direction TB
        N1["Prompt Injection /<br/>Jailbreaking"]
        N2["Data Poisoning /<br/>Model Manipulation"]
        N3["Credential Service<br/>Compromise"]
        N4["Physical Access<br/>Attacks"]
        N5["Cryptographic<br/>Breaks"]
        N6["Denial of<br/>Service"]
    end

    subgraph COMPLEMENTARY["Complementary Controls Needed"]
        direction TB
        C1["Input Validation<br/>& Guardrails"]
        C2["Data Provenance<br/>& Validation"]
        C3["Infrastructure<br/>Hardening"]
        C4["Physical Security"]
        C5["Crypto Migration<br/>Planning"]
        C6["DDoS Protection<br/>& Redundancy"]
    end

    T1 -->|defended by| D1
    T2 -->|contained by| D2
    T3 -->|blocked by| D3
    T4 -->|detected by| D4
    T5 -->|limited by| D5
    T6 -->|prevented by| D6

    N1 -.->|needs| C1
    N2 -.->|needs| C2
    N3 -.->|needs| C3
    N4 -.->|needs| C4
    N5 -.->|needs| C5
    N6 -.->|needs| C6

    classDef threatStyle fill:#b91c1c,stroke:#f87171,color:#f8fafc,stroke-width:2px
    classDef defenseStyle fill:#15803d,stroke:#4ade80,color:#f8fafc,stroke-width:2px
    classDef nongoalStyle fill:#78350f,stroke:#d97706,color:#f8fafc,stroke-width:1px
    classDef compStyle fill:#1e40af,stroke:#60a5fa,color:#f8fafc,stroke-width:1px

    class T1,T2,T3,T4,T5,T6 threatStyle
    class D1,D2,D3,D4,D5,D6 defenseStyle
    class N1,N2,N3,N4,N5,N6 nongoalStyle
    class C1,C2,C3,C4,C5,C6 compStyle
